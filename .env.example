# Telegram and OpenRouter credentials. Keep real values only in local .env or Portainer.
BOT_TOKEN=replace_with_telegram_bot_token
PAID_KEY=replace_with_openrouter_api_key
ADMIN_ID=replace_with_your_telegram_user_id

# Server-source deployment only: host project directory mounted into /app.
APP_PATH=/srv/dev-disk-by-uuid-<disk-uuid>/containers/img2prompt

# Persistent Obsidian data for both deployment variants.
SAVE_PATH=/srv/dev-disk-by-uuid-<disk-uuid>/storage/Documents/obsidian/30_Resources/AI_Models/Prompts
ATTACHMENTS_PATH=/srv/dev-disk-by-uuid-<disk-uuid>/storage/Documents/obsidian/attachments

# GitHub-image deployment only: GHCR image and tag built by GitHub Actions.
BOT_IMAGE=ghcr.io/your-github-account/img2prompt
IMAGE_TAG=main

# Proxy routing. PRIMARY_PROXY_URL is preferred; HTTP_PROXY remains a compatibility fallback.
PRIMARY_PROXY_URL=http://primary-proxy:8080
RESERVE_PROXY_URL=http://reserve-proxy:8080
HTTP_PROXY=http://primary-proxy:8080
HTTPS_PROXY=http://your-proxy-service:7890

# Container, Docker runtime and existing external networks.
CONTAINER_NAME=vision_bot
DOCKER_SOCKET_PATH=/var/run/docker.sock
APPLICATION_NETWORK=your_application_network
PROXY_NETWORK=your_proxy_network
