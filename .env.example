# Telegram and OpenRouter: obtain both values from BotFather and OpenRouter.
BOT_TOKEN=replace_with_telegram_bot_token
PAID_KEY=replace_with_openrouter_api_key

# Telegram numeric user ID allowed to use this private bot.
ADMIN_ID=replace_with_your_telegram_user_id

# Linux host path to the project folder mounted as /app in the container.
APP_PATH=/srv/dev-disk-by-uuid-<disk-uuid>/containers/img2prompt

# Linux host paths where Obsidian notes and reduced JPEG previews are stored.
SAVE_PATH=/srv/dev-disk-by-uuid-<disk-uuid>/storage/Documents/obsidian/30_Resources/AI_Models/Prompts
ATTACHMENTS_PATH=/srv/dev-disk-by-uuid-<disk-uuid>/storage/Documents/obsidian/attachments

# Optional proxy. Leave both empty when direct outbound access is available.
HTTP_PROXY=http://your-proxy-service:7890
HTTPS_PROXY=http://your-proxy-service:7890

# Container and Docker runtime settings.
CONTAINER_NAME=vision_bot
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Existing external Docker networks for the application and proxy services.
APPLICATION_NETWORK=your_application_network
PROXY_NETWORK=your_proxy_network
